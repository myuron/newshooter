{
  "mcpServers": {
    "serena":{
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "pnpm",
      "args": [
        "dlx",
        "@upstash/context7-mcp@latest"
      ]
    }
  }
}
